---
import { getCollection } from 'astro:content';
import DocsPage from '../docs/[...slug].astro';
import { getContentParamSlug } from '@/lib/content-path';

export async function getStaticPaths() {
	const integrationsPrefix = 'integrations/';
	const integrations = (await getCollection('docs')).filter((entry) =>
		entry.id.startsWith(integrationsPrefix) && entry.id !== 'integrations/index',
	);

	return integrations.map((entry) => {
		const routeEntryId = entry.id.slice(integrationsPrefix.length);
		return {
			params: { slug: getContentParamSlug(routeEntryId) },
			props: { entry },
		};
	});
}

const { entry } = Astro.props;
const integrationsPrefix = 'integrations/';
---

<DocsPage
	entry={entry}
	routePrefix="/integrations"
	entryIdPrefix={integrationsPrefix}
	breadcrumbName="Integrations"
/>
