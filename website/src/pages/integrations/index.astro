---
import { getEntry } from 'astro:content';
import DocsPage from '../docs/[...slug].astro';

const entry = await getEntry('docs', 'integrations');
if (!entry) {
	throw new Error('Missing integrations index content');
}
---

<DocsPage
	entry={entry}
	routePrefix="/integrations"
	entryIdPrefix="integrations"
	breadcrumbName="Integrations"
/>
