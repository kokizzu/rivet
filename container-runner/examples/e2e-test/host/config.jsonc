{
  // Host-based e2e: run the engine natively on dedicated ports (7420/7421/7430) so it
  // never collides with any other local Rivet engine (e.g. a rivetkit dev engine on 6420).
  // Everything runs on the host over loopback — native macOS networking, no Docker
  // virtualization — so the engine's HTTP client reaches the container-runner normally.
  "topology": {
    "datacenter_label": 1,
    "datacenters": {
      "default": {
        "datacenter_label": 1,
        "is_leader": true,
        "public_url": "http://127.0.0.1:7420",
        "peer_url": "http://127.0.0.1:7421"
      }
    }
  },
  "guard": { "port": 7420 },
  "api_peer": { "port": 7421 },
  "metrics": { "port": 7430 }
}
