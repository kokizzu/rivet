{
  // Single-node self-hosted engine for local e2e.
  //
  // public_url is what the engine hands the container-runner as `x-rivet-endpoint`
  // (the address it connects back to). On the compose network the engine is reachable
  // as `rivet-engine`. (Default is http://127.0.0.1:6420, which from inside the game
  // container would point at itself.)
  "topology": {
    "datacenter_label": 1,
    "datacenters": {
      "default": {
        "datacenter_label": 1,
        "is_leader": true,
        "public_url": "http://rivet-engine:6420",
        "peer_url": "http://rivet-engine:6421"
      }
    }
  }
}
