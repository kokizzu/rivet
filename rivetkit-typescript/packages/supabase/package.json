{
	"name": "@rivetkit/supabase",
	"version": "2.3.2",
	"description": "Supabase Edge Functions integration for RivetKit actors",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"supabase",
		"supabase-functions",
		"edge-functions",
		"deno",
		"serverless",
		"edge",
		"wasm",
		"actor",
		"microservices"
	],
	"sideEffects": false,
	"files": [
		"dist",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.mts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts",
		"check-types": "tsc --noEmit",
		"size": "size-limit",
		"check-edge-closure": "node ../../../scripts/ci/check-edge-native-closure.mjs"
	},
	"dependencies": {
		"@rivetkit/rivetkit-wasm": "workspace:*",
		"cbor-x": "^1.6.0",
		"pino": "^9.5.0"
	},
	"devDependencies": {
		"@size-limit/file": "^11.1.6",
		"@types/node": "^22.0.0",
		"rivetkit": "workspace:^",
		"size-limit": "^11.1.6",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0"
}
